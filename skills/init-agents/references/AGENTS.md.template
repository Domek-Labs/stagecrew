---
# AGENTS.md — Per-Repo-Standards fuer /create-issue und /work-issue.
# Diese Datei ueberschreibt die Skill-Defaults (L1) und kann pro Issue
# noch durch einen "## Standards-Override"-Block (L3) ueberschrieben werden.
#
# Lege sie im Repo-Root ab und commite sie auf den Default-Branch.

work-issue:
  branch_pattern: "feature/<scope>-<short>"      # default
  default_branch: main                           # main | dev
  pr_base: main                                  # main | dev
  commit_format: "conventional"                  # type(scope): description
  syntax_check: "node --check"                   # node | python -m py_compile | tsc --noEmit | ...
  smoke_test: "docker compose build && docker compose up -d --force-recreate"
  deploy_command: ""                             # optional, else skip
  linter: ""                                     # optional

  commit_identity:                                 # optional — author identity for all loop commits
    name: "Your Name"
    email: "<id>+<user>@users.noreply.github.com"  # never a company/shared email

  hard_gates:
    - "No direct edit on main"
    - "Every MCP tool needs a test example in its doc block"
    - "No new secrets in repo"
    - "no_unconfigured_coauthors"                  # no `Co-authored-by:` trailer in commits/PRs unless explicitly configured (prevents bot/foreign accounts becoming contributors; GitHub appends co-author lines from individual commits on squash-merge, so individual commits must be clean)

  default_oos:
    - "Multi-User-Support"
    - "Web-Channel-Approvals"

  ac_templates:
    - "Code passes `node --check` (oder Repo-Aequivalent)"
    - "Documentation in README/CLAUDE.md aktualisiert"
    - "No new secrets in repo (Secret-Check passed)"

# Optional: Component Registry (opt-in, absent = zero behavior change)
# Uncomment + fill only if the repo has real reusable-component patterns
# (frontend framework and/or backend domain layer). When set, the loop
# enforces registry reuse: Validator gates in-scope issues, Implementer
# refuses inline duplicates, Critic runs dupe detection.
#
# components:
#   registry_path: "docs/components.md"          # required if block present
#   code_globs:                                  # required — the code source-of-truth
#     - "src/components/**/*.tsx"
#     - "src/domain/**/*.ts"
#   usage_policy: "prefer_existing"              # prefer_existing (warn) | strict (STOP + ADR required)
#   scope: "both"                                # frontend | backend | both (default both)

# Optional: Visual Reviewer Gate (opt-in, absent = zero behavior change)
# Uncomment + fill only if the repo has a frontend. When set, /work-issue runs
# a Visual Reviewer stage (3.5, between Tester and Critic) for frontend-scoped
# issues: it serves the built frontend and inspects it with Playwright (per
# route x viewport, mobile-first), then posts [stage:visual] PASS|FAIL with
# screenshots. A gate, not a loop-type. Requires the Playwright MCP; absent -> skipped.
#
# visual:
#   serve_command: "npm run preview"           # required if block present — serve the built frontend
#   base_url: "http://localhost:4173"          # required — where the served app answers
#   viewports:                                 # optional; default mobile-first
#     - { w: 390,  h: 844,  label: mobile }
#     - { w: 1280, h: 800,  label: desktop }
#   routes: ["/"]                              # optional default routes; issues can override/extend
#   console_error_policy: "fail"               # fail | warn (default fail)
#   screenshot_dir: ".stagecrew/visual"        # optional
#   scope: "frontend"                          # visual review only applies to frontend work

# Multi-Type-Loop-System
# Enabled-Types: 'code' (Default, Software-Implementation) und 'research'
# (Erkenntnis-Generierung mit Test-Matrix). Pro Type kann ein Overrides-Block
# Standards-Werte ueberschreiben (z.B. ac_templates: [] fuer docs-only Research).
loop_types:
  enabled: [code, research]
  default: code
  type_overrides:
    research:
      ac_templates: []                     # docs-only -> Issue liefert Ersatz-AC
      smoke_test: "wc -w docs/research/*.md"   # Doc-Quality statt Build-GREEN
    # Roadmap — auskommentiert bis implementiert (keine Version-Tags):
    # text:
    #   ac_templates:
    #     - "markdownlint passt"
    #     - "linkcheck gruen"
    # decision:
    #   ac_templates:
    #     - "ADR-Format korrekt"
    #     - "Constraint-Coverage vollstaendig"
    # diagnostic:
    #   ac_templates:
    #     - "Hypothesen reproduzierbar"
    #     - "Fix-Spec klar"
